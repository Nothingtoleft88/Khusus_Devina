const QuizEngine = ({ subjectId, setCurrentRoute, setQuizResult, saveResultToCloud }) => {
  const subject = SUBJECTS.find(s => s.id === subjectId);
  const [questions, setQuestions] = useState([]);
  
  const [currentIndex, setCurrentIndex] = useState(0);
  const [answers, setAnswers] = useState({}); // { qId: optionIndex }
  const [marked, setMarked] = useState({}); // { qId: boolean }
  const [timeLeft, setTimeLeft] = useState(subject ? subject.time * 60 : 0);

  // Inisialisasi dan Acak Soal
  useEffect(() => {
    if (subject) {
      const subjectQs = MOCK_QUESTIONS.filter(q => q.subject === subjectId);
      // Mengacak urutan soal setiap kali tryout dimulai agar bisa dipakai berulang
      const shuffled = [...subjectQs].sort(() => 0.5 - Math.random());
      setQuestions(shuffled);
      setTimeLeft(subject.time * 60);
      setCurrentIndex(0);
      setAnswers({});
      setMarked({});
    }
  }, [subjectId, subject]);

  // Timer Effect
  useEffect(() => {
    if (timeLeft <= 0 && questions.length > 0) {
      finishQuiz();
      return;
    }
    const timer = setInterval(() => {
      setTimeLeft(prev => prev - 1);
    }, 1000);
    return () => clearInterval(timer);
  }, [timeLeft, questions]);

  const formatTime = (seconds) => {
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
  };

  const handleAnswer = (optionIndex) => {
    setAnswers(prev => ({ ...prev, [questions[currentIndex].id]: optionIndex }));
  };

  const toggleMark = () => {
    setMarked(prev => ({ 
      ...prev, 
      [questions[currentIndex].id]: !prev[questions[currentIndex].id] 
    }));
  };

  const finishQuiz = () => {
    // Calculate result
    let correct = 0;
    let wrong = 0;
    let blank = 0;
    
    questions.forEach(q => {
      if (answers[q.id] === undefined) {
        blank++;
      } else if (answers[q.id] === q.correct) {
        correct++;
      } else {
        wrong++;
      }
    });

    // Simulate IRT Score (Base 200 + max 800 spread based on percentage)
    const rawScore = correct / questions.length;
    const irtScore = Math.floor(200 + (rawScore * 800));

    const resultData = {
      subject: subject.name,
      total: questions.length,
      correct, wrong, blank,
      score: irtScore,
      questions,
      answers
    };

    setQuizResult(resultData);
    if (saveResultToCloud) saveResultToCloud(resultData);
    setCurrentRoute('result');
  };

  const currentQ = questions[currentIndex];

  if (questions.length === 0 || !currentQ) {
    return (
      <div className="min-h-[calc(100vh-4rem)] flex items-center justify-center bg-gray-100">
        <div className="flex flex-col items-center space-y-4">
          <div className="w-10 h-10 border-4 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
          <p className="text-gray-600 font-bold">Mengacak & Menyiapkan Soal...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="bg-gray-100 min-h-[calc(100vh-4rem)] flex flex-col md:flex-row">
      
      {/* Main Area */}
      <div className="flex-1 flex flex-col h-[calc(100vh-4rem)] md:h-auto overflow-y-auto">
        {/* Header CBT */}
        <div className="bg-white border-b border-gray-200 px-6 py-4 flex justify-between items-center sticky top-0 z-10 shadow-sm">
          <div>
            <h2 className="text-xl font-bold text-gray-800">{subject.name}</h2>
            <p className="text-sm text-gray-500">Soal ke {currentIndex + 1} dari {questions.length}</p>
          </div>
          <div className="flex items-center space-x-3 bg-red-50 text-red-600 px-4 py-2 rounded-lg font-mono font-bold text-lg border border-red-100">
            <Clock className="w-5 h-5" />
            <span>{formatTime(timeLeft)}</span>
          </div>
        </div>

        {/* Question Area */}
        <div className="p-6 md:p-8 flex-grow max-w-4xl w-full mx-auto">
          <div className="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 md:p-8 mb-6">
            <div className="text-lg text-gray-800 leading-relaxed mb-8 whitespace-pre-wrap">
              {currentQ.text}
            </div>

            <div className="space-y-4">
              {currentQ.options.map((opt, idx) => {
                const isSelected = answers[currentQ.id] === idx;
                const labels = ['A', 'B', 'C', 'D', 'E'];
                return (
                  <button
                    key={idx}
                    onClick={() => handleAnswer(idx)}
                    className={`w-full text-left p-4 rounded-xl border-2 transition-all flex items-start group ${
                      isSelected 
                        ? 'border-indigo-600 bg-indigo-50' 
                        : 'border-gray-200 hover:border-indigo-300 hover:bg-gray-50'
                    }`}
                  >
                    <div className={`w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center font-bold mr-4 ${
                      isSelected ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600 group-hover:bg-indigo-100 group-hover:text-indigo-600'
                    }`}>
                      {labels[idx]}
                    </div>
                    <span className={`mt-1 ${isSelected ? 'text-indigo-900 font-medium' : 'text-gray-700'}`}>
                      {opt}
                    </span>
                  </button>
                );
              })}
            </div>
          </div>
        </div>

        {/* Bottom Nav */}
        <div className="bg-white border-t border-gray-200 p-4 sticky bottom-0 z-10 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
          <div className="max-w-4xl mx-auto flex justify-between items-center">
            <button
              onClick={() => setCurrentIndex(prev => Math.max(0, prev - 1))}
              disabled={currentIndex === 0}
              className="px-6 py-3 rounded-xl font-semibold flex items-center disabled:opacity-50 disabled:cursor-not-allowed text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors"
            >
              <ChevronLeft className="w-5 h-5 mr-1" /> Sebelumnya
            </button>
            
            <label className="flex items-center space-x-3 cursor-pointer bg-yellow-50 px-6 py-3 rounded-xl border border-yellow-200 hover:bg-yellow-100 transition-colors">
              <input 
                type="checkbox" 
                className="w-5 h-5 text-yellow-500 rounded border-gray-300 focus:ring-yellow-500"
                checked={marked[currentQ.id] || false}
                onChange={toggleMark}
              />
              <span className="font-semibold text-yellow-700">Ragu - ragu</span>
            </label>

            <button
              onClick={() => setCurrentIndex(prev => Math.min(questions.length - 1, prev + 1))}
              disabled={currentIndex === questions.length - 1}
              className="px-6 py-3 rounded-xl font-semibold flex items-center disabled:opacity-50 disabled:cursor-not-allowed text-white bg-indigo-600 hover:bg-indigo-700 transition-colors"
            >
              Selanjutnya <ChevronRight className="w-5 h-5 ml-1" />
            </button>
          </div>
        </div>
      </div>

      {/* Sidebar / Grid Soal */}
      <div className="w-full md:w-80 bg-white border-l border-gray-200 flex flex-col h-[300px] md:h-[calc(100vh-4rem)] order-first md:order-last">
        <div className="p-4 border-b border-gray-200 bg-gray-50">
          <h3 className="font-bold text-gray-800">Navigasi Soal</h3>
        </div>
        <div className="p-4 flex-grow overflow-y-auto">
          <div className="grid grid-cols-5 gap-3">
            {questions.map((q, idx) => {
              const isAnswered = answers[q.id] !== undefined;
              const isMarked = marked[q.id];
              const isCurrent = currentIndex === idx;
              
              let bgColor = 'bg-white';
              let borderColor = 'border-gray-300';
              let textColor = 'text-gray-600';

              if (isMarked) {
                bgColor = 'bg-yellow-400';
                borderColor = 'border-yellow-500';
                textColor = 'text-white';
              } else if (isAnswered) {
                bgColor = 'bg-green-500';
                borderColor = 'border-green-600';
                textColor = 'text-white';
              }

              if (isCurrent) {
                borderColor = 'border-blue-600 border-4';
              }

              return (
                <button
                  key={q.id}
                  onClick={() => setCurrentIndex(idx)}
                  className={`w-10 h-10 rounded-lg flex items-center justify-center font-bold text-sm border ${bgColor} ${borderColor} ${textColor} hover:opacity-80 transition-all`}
                >
                  {idx + 1}
                </button>
              );
            })}
          </div>

          {/* Legend */}
          <div className="mt-8 space-y-3">
            <div className="flex items-center text-sm text-gray-600"><div className="w-4 h-4 bg-green-500 rounded mr-3"></div> Sudah Dijawab</div>
            <div className="flex items-center text-sm text-gray-600"><div className="w-4 h-4 bg-yellow-400 rounded mr-3"></div> Ragu-ragu</div>
            <div className="flex items-center text-sm text-gray-600"><div className="w-4 h-4 bg-white border border-gray-300 rounded mr-3"></div> Belum Dijawab</div>
          </div>
        </div>
        <div className="p-4 border-t border-gray-200 bg-gray-50">
          <button 
            onClick={() => {
              if(window.confirm('Apakah kamu yakin ingin mengakhiri ujian? Pastikan semua soal telah dicek.')) finishQuiz();
            }}
            className="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-xl transition-colors shadow-sm"
          >
            Hentikan Ujian
          </button>
        </div>
      </div>
    </div>
  );
};

