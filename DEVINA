export default function App() {
  const [currentRoute, setCurrentRoute] = useState('home'); // home, dashboard, quiz, result
  const [user, setUser] = useState(null);
  const [targetSubject, setTargetSubject] = useState(null);
  const [quizResult, setQuizResult] = useState(null);
  const [history, setHistory] = useState([]);

  // 1. Inisialisasi Auth Firebase
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (error) {
        console.error("Auth error:", error);
      }
    };
    initAuth();
    
    const unsubscribe = onAuthStateChanged(auth, setUser);
    return () => unsubscribe();
  }, []);

  // 2. Fetch History Data Real-time
  useEffect(() => {
    if (!user) return;
    
    const historyRef = collection(db, 'artifacts', appId, 'users', user.uid, 'history');
    const unsubscribe = onSnapshot(historyRef, 
      (snapshot) => {
        const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
        // Urutkan dari yang terbaru
        data.sort((a, b) => b.timestamp - a.timestamp);
        setHistory(data);
      }, 
      (error) => {
        console.error("Error fetching history:", error);
      }
    );
    
    return () => unsubscribe();
  }, [user]);

  // 3. Fungsi Save Result
  const saveResultToCloud = async (resultData) => {
    if (!user) return;
    try {
      const historyRef = collection(db, 'artifacts', appId, 'users', user.uid, 'history');
      await addDoc(historyRef, {
        subject: resultData.subject,
        score: resultData.score,
        correct: resultData.correct,
        wrong: resultData.wrong,
        blank: resultData.blank,
        timestamp: Date.now()
      });
    } catch (error) {
      console.error("Gagal menyimpan hasil tryout:", error);
    }
  };

  // Scroll to top on route change
  useEffect(() => {
    window.scrollTo(0, 0);
  }, [currentRoute]);

  return (
    <div className="min-h-screen bg-gray-50 font-sans selection:bg-indigo-200">
      <Navbar currentRoute={currentRoute} setCurrentRoute={setCurrentRoute} user={user} />
      
      <main>
        {currentRoute === 'home' && <LandingPage setCurrentRoute={setCurrentRoute} user={user} />}
        {currentRoute === 'dashboard' && <Dashboard setCurrentRoute={setCurrentRoute} setTargetSubject={setTargetSubject} user={user} history={history} />}
        {currentRoute === 'quiz' && <QuizEngine subjectId={targetSubject} setCurrentRoute={setCurrentRoute} setQuizResult={setQuizResult} saveResultToCloud={saveResultToCloud} />}
        {currentRoute === 'result' && <ResultView result={quizResult} setCurrentRoute={setCurrentRoute} />}
      </main>

      {currentRoute !== 'quiz' && (
        <footer className="bg-white border-t border-gray-200 py-12 mt-auto">
          <div className="max-w-7xl mx-auto px-4 text-center text-gray-500">
            <div className="flex items-center justify-center mb-4">
              <Zap className="w-6 h-6 text-indigo-400 mr-2" />
